# ─── ATMOS Environment Variables ───
# Copy this to .env and fill in your values. NEVER commit .env to git.

# Hugging Face
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_USER_ID=your_user_id_here
TELEGRAM_SOURCE_CHANNELS=Channel1,Channel2

# Telegram Userbot (for channel searching / large files)
USERBOT_SESSION=your_session_string_here

# Google Drive
GDRIVE_FOLDER_ID=your_folder_id_here
GDRIVE_CREDENTIALS=  # Contents of token.json (single line)

# TMDB
TMDB_API_KEY=your_tmdb_api_key_here

# Admin
ADMIN_PASSWORD=use_a_strong_password_here
